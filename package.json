{
  "name": "q-ching",
  "version": "0.1.0",
  "private": true,
  "description": "An I-Ching oracle cast from quantum randomness and the motion of your own hand.",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*",
    "experiments/*"
  ],
  "scripts": {
    "build:core": "npm run build --workspace @hylaean/core",
    "test:core": "npm run test --workspace @hylaean/core",
    "dev:web": "npm run dev --workspace @hylaean/web",
    "build:web": "npm run build --workspace @hylaean/web",
    "tui": "npm run start --workspace @hylaean/tui",
    "mcp": "npm run start --workspace @hylaean/mcp",
    "build:mcp": "npm run build --workspace @hylaean/mcp",
    "experiment": "npm run start --workspace @hylaean/exp-oracle-guided",
    "build": "npm run build:core && npm run build:web && npm run build --workspace @hylaean/tui && npm run build:mcp",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish"
  },
  "engines": {
    "node": ">=20"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "4.62.2"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0"
  }
}
