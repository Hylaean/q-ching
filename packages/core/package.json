{
  "name": "@q-ching/core",
  "version": "0.1.0",
  "description": "Platform-agnostic I-Ching engine: entropy pool, QRNG clients, casting math, and the 64 hexagrams.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "tsc -p tsconfig.test.json && node --test dist/*.test.js"
  },
  "sideEffects": false
}
