{
  "name": "@q-ching/tui",
  "version": "0.1.0",
  "description": "q-ching in your terminal: an I-Ching oracle cast from live quantum entropy and the rhythm of your own typing.",
  "type": "module",
  "license": "MIT",
  "author": "Jean Llorca <jean@hylaean.com>",
  "homepage": "https://github.com/Hylaean/q-ching#readme",
  "bugs": "https://github.com/Hylaean/q-ching/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Hylaean/q-ching.git",
    "directory": "apps/tui"
  },
  "keywords": [
    "i-ching",
    "iching",
    "oracle",
    "hexagram",
    "cli",
    "tui",
    "ink",
    "divination"
  ],
  "bin": {
