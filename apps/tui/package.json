  },
  "files": ["dist", "src"],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "start": "tsx src/index.tsx",
    "dev": "tsx watch src/index.tsx",
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@q-ching/core": "^0.1.0",
    "chalk": "^5.3.0",
    "ink": "^7.1.0",
    "ink-big-text": "^2.0.0",
    "ink-gradient": "^4.0.1",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "tsx": "^4.16.0",
    "typescript": "^6.0.3"
  }
}
