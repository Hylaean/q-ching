#!/bin/sh
#
# Pre-commit gate — mirrors CI (.github/workflows/ci.yml): type-check every
# workspace (tsc) and run the core test suite before a commit can land. This
# catches the type errors that only surface under the dependency versions
# pinned in package-lock.json (e.g. TypeScript's stricter lib types).
#
# IMPORTANT: CI installs with `npm ci`, so it builds against the *locked*
# dependency versions. A local node_modules can drift — an older TypeScript will
# happily compile code that CI's newer, stricter TypeScript rejects. If you've
# just pulled or changed package-lock.json, run `npm ci` first so this hook
# checks exactly what CI will build.
#
# Wired up automatically by the root "prepare" script (sets core.hooksPath).
# Bypass in a pinch with:  git commit --no-verify

set -e

# Run from the repo root regardless of where git invokes the hook.
cd "$(git rev-parse --show-toplevel)"

# Warn (don't block) if node_modules looks out of sync with the lockfile —
# the exact blind spot that lets a CI-only type error slip through locally.
if [ package-lock.json -nt node_modules/.package-lock.json ]; then
  echo "pre-commit: ⚠  package-lock.json is newer than node_modules — run 'npm ci' so this matches CI."
fi

echo "pre-commit: type-checking + building all workspaces …"
npm run build

echo "pre-commit: running core tests …"
npm run test:core

echo "pre-commit: ✓ all workspaces build and core tests pass"
